{
  "$schema": "https://opencode.ai/tui.json",
  // "theme": "everforest",
  "theme": "system",
  "keybinds": {
    "leader": "ctrl+o"
  },
  "scroll_speed": 1,
  "scroll_acceleration": {
    "enabled": true
  },
  "diff_style": "auto",
  "mouse": true,
  "attention": {
    "enabled": true,
    "notifications": true,
    "sound": true
  }
}
