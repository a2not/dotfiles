{
  "$schema": "https://unpkg.com/@aliou/pi-guardrails@0.15.0/schema.json",
  "version": "0.13.0-20260619",
  "applyBuiltinDefaults": true,
  "onboarding": {
    "completed": true,
    "completedAt": "2026-06-27T03:40:30.132Z",
    "version": "0.13.0-20260619"
  },
  "permissionGate": {
    "patterns": [
      {
        "pattern": "git add",
        "description": "git add"
      },
      {
        "pattern": "git commit",
        "description": "git commit"
      },
      {
        "pattern": "git tag",
        "description": "git tag"
      },
      {
        "pattern": "git config"
      },
      {
        "pattern": "rm .*",
        "description": "removing of any files.",
        "regex": true
      }
    ],
    "autoDenyPatterns": [
      {
        "pattern": "git -c",
        "description": "inline override of git config"
      },
      {
        "pattern": "git branch -(d|D)",
        "regex": true
      },
      {
        "pattern": "sudo"
      },
      {
        "pattern": "git push"
      },
      {
        "pattern": "git reset"
      }
    ]
  }
}
