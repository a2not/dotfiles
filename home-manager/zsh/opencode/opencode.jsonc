{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "share": "disabled",
  "instructions": [
    "AGENTS.md",
    "CONTRIBUTING.md",
    "docs/guidelines.md",
    ".cursor/rules/*.md",
    "CLAUDE.md"
  ],
  "default_agent": "architect",
  "permission": {
    "bash": {
      "*": "ask",
      "which *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "git branch *": "allow",
      "git branch -d *": "deny",
      "git status*": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git add *": "deny",
      "git commit": "deny",
      "git commit *": "deny",
      "git push": "deny",
      "git push *": "deny",
      "sudo *": "deny",
      "rm *": "deny"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    }
  },
  "model": "sakura/Kimi-K2.6",
  "provider": {
    "github-copilot": {
      "npm": "@github/copilot",
      "name": "GitHub Copilot",
      "models": {
        "gpt-4.1": {
          "name": "GPT-4.1"
        }
      }
    },
    "sakura": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Sakura AI Engine",
      "options": {
        "baseURL": "https://api.ai.sakura.ad.jp/v1",
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "models": {
        "preview/Kimi-K2.6": {
          "name": "Kimi-K2.6"
        },
        "Qwen3-Coder-480B-A35B-Instruct-FP8": {
          "name": "Qwen3-Coder-480B-A35B-Instruct-FP8"
        },
        "Qwen3-Coder-30B-A3B-Instruct": {
          "name": "Qwen3-Coder-30B-A3B-Instruct"
        }
      }
    }
  },
  "disabled_providers": [
    "openai",
    "gemini",
    "opencode",
    "github-copilot"
  ]
}
