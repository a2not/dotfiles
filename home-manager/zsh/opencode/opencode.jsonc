{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "CONTRIBUTING.md",
    "docs/guidelines.md",
    ".cursor/rules/*.md",
    "CLAUDE.md"
  ],
  "default_agent": "architect",
  "plugin": [
    "oh-my-opencode"
  ],
  "permission": {
    "bash": {
      "*": "allow",
      "git add *": "deny",
      "git commit *": "deny",
      "git push": "deny",
      "git push *": "deny",
      "sudo *": "deny",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/*": "deny"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "external_directory": {
      "/tmp/**": "allow"
    }
  },
  "model": "sakura/Kimi-K2.5",
  "provider": {
    "github-copilot": {
      "npm": "@github/copilot",
      "name": "GitHub Copilot",
      "models": {
        "gpt-4.1": {
          "name": "GPT-4.1"
        }
      }
    },
    "sakura": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Sakura AI Engine",
      "options": {
        "baseURL": "https://api.ai.sakura.ad.jp/v1",
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "models": {
        "preview/Kimi-K2.5": {
          "name": "Kimi-K2.5"
        },
        "Qwen3-Coder-480B-A35B-Instruct-FP8": {
          "name": "Qwen3-Coder-480B-A35B-Instruct-FP8"
        },
        "Qwen3-Coder-30B-A3B-Instruct": {
          "name": "Qwen3-Coder-30B-A3B-Instruct"
        }
      }
    }
  },
  "disabled_providers": [
    "openai",
    "gemini",
    "opencode"
  ],
  // NOTE: agents from https://gist.github.com/mjakl/490ef1d85fffea810dfe2f17069bc08b
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    }
  }
}
